# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AstraDB (DataStax)
ASTRA_DB_APPLICATION_TOKEN=AstraCS:your-token
ASTRA_DB_API_ENDPOINT=https://your-db-id-your-region.apps.astra.datastax.com
ASTRA_DB_COLLECTION=codevault_chunks

# Optional: use in-memory vector store for local dev without AstraDB
USE_IN_MEMORY_VECTOR_STORE=true
